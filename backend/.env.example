# ── OpenAI (Whisper transcription) ──────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your_openai_key_here...

# ── Hugging Face (meeting summarization) ────────────────────────────────────
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your-token-here

# ── Database ────────────────────────────────────────────────────────────────
# Local dev: SQLite (default, no setup needed)
# Production (Render): PostgreSQL — Render injects DATABASE_URL automatically
# DATABASE_URL=postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///./meetlite.db

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Update with your Render frontend URL after deploy
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
